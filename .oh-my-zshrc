#!/usr/bin/env bash

export ZSH="$HOME/.oh-my-zsh";

ZSH_THEME=""  # simple?

plugins=(
    docker
    docker-compose
    dotenv
    fig
    git
    golang
    helm
    macos
    npm
    oc
    pip
    poetry
    python
    rust
    screen
    sublime
    sudo
    virtualenv
    vscode
)

source $ZSH/oh-my-zsh.sh
